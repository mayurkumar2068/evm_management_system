      "item": [
        {
          "name": "Survey Questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/PSSurvey/survey_questions",
            "description": "Checklist questions (login ke baad token chahiye)"
          },
          "response": []
        }
      ]
    }
  ]
}
