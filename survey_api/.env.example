# Copy to ".env" and fill in your values.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Mayur@8665
DB_NAME=MPSECIEMS

# Set to "true" if your MySQL requires TLS (you mentioned TLS_AES_128_GCM_SHA256).
DB_SSL=true

# API server port
PORT=3000

# Max photos allowed per survey (returned with the checklist config).
MAX_IMAGES=10

# Auth: secret used to sign session tokens (use a long random string in prod).
TOKEN_SECRET=change-me-to-a-long-random-string
# Token validity in hours.
TOKEN_TTL_HOURS=12

# Shared password for the district-based service login (one for all districts).
DISTRICT_PASSWORD=admin123
